<!DOCTYPE html>
<html>
<head>
    <title>Margherita</title>

    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            text-align: center;
            font-family: Arial;
        }
    </style>
</head>
<body>

<div>
    <h2>Holas!</h2>

    <!-- margherita -->
    <svg width="200" height="200" viewBox="0 0 200 200">
        <g fill="white" stroke="black" stroke-width="2">
            <ellipse cx="100" cy="40" rx="15" ry="35"/>
            <ellipse cx="100" cy="160" rx="15" ry="35"/>
            <ellipse cx="40" cy="100" rx="35" ry="15"/>
            <ellipse cx="160" cy="100" rx="35" ry="15"/>
            <ellipse cx="60" cy="60" rx="15" ry="35" transform="rotate(-45 60 60)"/>
            <ellipse cx="140" cy="60" rx="15" ry="35" transform="rotate(45 140 60)"/>
            <ellipse cx="60" cy="140" rx="15" ry="35" transform="rotate(45 60 140)"/>
            <ellipse cx="140" cy="140" rx="15" ry="35" transform="rotate(-45 140 140)"/>
        </g>
        <circle cx="100" cy="100" r="25" fill="yellow" stroke="black" stroke-width="2"/>
    </svg>

    <br><br>

    <!-- primo bottone -->
    <button id="btn1" onclick="primoClick()">Clicca qui</button>

    <!-- secondo bottone (nascosto) -->
    <button id="btn2" onclick="secondoClick()" style="display:none;">Curiosa?</button>

    <!-- messaggi -->
    <p id="msg1" style="display:none;">🌼 Sorpresa! 🌼</p>
    <p id="msg2" style="display:none;">Hai vinto un trattamento!<p>

</div>

<script>
    function primoClick() {
        document.getElementById("msg1").style.display = "block";

        // nasconde primo bottone
        document.getElementById("btn1").style.display = "none";

        // mostra secondo bottone
        document.getElementById("btn2").style.display = "inline";
    }

    function secondoClick() {
        document.getElementById("msg2").style.display = "block";
    }
</script>

</body>
</html>
